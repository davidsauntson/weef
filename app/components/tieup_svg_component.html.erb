<svg width="<%= treadles.size * 20 %>" height="<%= shafts.size * 20 %>">

    <% treadles.each do |treadle| %>
        <%# draw a black square for each shaft tied to this treadle %>
        <% treadle.shafts.each do |shaft| %>
            <rect x="<%= (treadle.id - 1) * 20 %>" y="<%= (shafts.size - shaft.id) * 20 %>" width="20" height="20" fill="black" />
        <% end %>

        <%# draw the grid for that treadle (order of shafts doesn't matter) %>
        <% shafts.each do |shaft| %>
            <rect x="<%= (treadle.id - 1) * 20 %>" y="<%= (shaft.id - 1) * 20 %>" width="20" height="20" stroke="grey" fill="transparent" />
        <% end %>
    <% end %>    
</svg>
