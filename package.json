{
  "name": "weef",
  "version": "0.1.0",
  "description": "Something to help me print tie-ups, treadlings and threadings for my weaves.",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:css": "sass ./app/assets/stylesheets/application.sass.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "prepare": "husky"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "husky": "^9.1.7",
    "sass": "^1.98.0"
  },
  "dependencies": {
    "govuk-frontend": "^6.1.0"
  },
  "lint-staged": {
      "*.rb": [
          "bundle exec rubocop -A"
      ]
  }
}

